:: StoryScript [script]
(function () {
  function attach () {
    var story = document.querySelector('tw-story');
    if (!story) { return setTimeout(attach, 50); }
    new MutationObserver(function () {
      window.scrollTo(0, 0);
    }).observe(story, { childList: true });
  }
  attach();
})();

:: StoryStylesheet [stylesheet]
html, body {
  background: #fafaf7;
  color: #222;
  margin: 0;
  padding: 0;
  min-height: 100vh;
}

tw-story {
  background: #fafaf7 !important;
  color: #222 !important;
  font-family: Georgia, serif !important;
  font-size: 17px !important;
  line-height: 1.6 !important;
  display: block !important;
  position: static !important;
  box-sizing: border-box !important;
  margin: 0 auto !important;
  max-width: 680px !important;
  padding: 3rem 1.5rem 4rem !important;
  min-height: 100vh !important;
  text-align: left !important;
}

tw-passage {
  display: block !important;
  position: static !important;
  padding: 0 !important;
  margin: 0 !important;
  text-align: left !important;
}

tw-include, tw-hook, tw-expression { display: inline; }

h1, h2, h3 { font-weight: normal; margin: 1.4rem 0 .6rem; }
h1 { font-size: 1.6rem; }
h2 { font-size: 1.2rem; }

p { margin: 0 0 1rem; }

tw-link, .enchantment-link {
  color: #224 !important;
  text-decoration: underline !important;
  cursor: pointer;
}
tw-link:hover, .enchantment-link:hover { color: #113 !important; }

blockquote {
  border-left: 3px solid #999;
  margin: 1rem 0;
  padding: 0 0 0 1rem;
  font-style: italic;
  color: #555;
}

hr { border: 0; border-top: 1px solid #bbb; margin: 2rem 0; }

ol, ul { padding-left: 1.4rem; }
ol li, ul li { margin-bottom: .8rem; }

.screen, .email, .thread, .letter {
  border: 1px solid #bbb;
  padding: .7rem 1rem;
  margin: 1rem 0;
  background: #fff;
  font-size: 14px;
  white-space: pre-line;
}
.screen {
  font-family: "Courier New", monospace;
  font-size: 13px;
}
.letter {
  font-family: Georgia, serif;
  font-size: 15px;
  background: #fcfbf6;
}